{
    "name": "web",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:cap": "cross-env CAPACITOR=true bun run build && bunx cap sync",
        "cap:run:android": "bunx cap run android",
        "cap:run:ios": "bunx cap run ios",
        "cap:sync": "bunx cap sync",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "dev": "vite dev",
        "format": "prettier --write . --ignore-path ../../.prettierignore",
        "format:check": "prettier --check . --ignore-path ../../.prettierignore",
        "prepare": "svelte-kit sync || echo ''",
        "preview": "vite preview"
    },
    "dependencies": {
        "@ark-ui/svelte": "^5.19.1",
        "@capacitor/android": "^8.0.2",
        "@capacitor/core": "^8.0.2",
        "@capacitor/ios": "^8.0.2",
        "@cartamd/plugin-anchor": "^2.2.0",
        "@cartamd/plugin-code": "^4.2.0",
        "@cartamd/plugin-emoji": "^4.3.0",
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.3",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.41.0",
        "@neodrag/svelte": "^3.0.0-next.8",
        "@repo/clashofclans-client": "workspace:*",
        "@sentry/sveltekit": "^10.45.0",
        "@tanstack/svelte-query": "^5.0.0",
        "@types/ua-parser-js": "^0.7.39",
        "@typescript/native-preview": "^7.0.0-dev.20260322.1",
        "animejs": "^4.3.6",
        "better-auth": "^1.5.5",
        "carta-md": "^4.11.1",
        "codemirror": "^6.0.2",
        "emojilib": "^4.0.2",
        "isomorphic-dompurify": "^3.7.1",
        "prettier": "^3.8.1",
        "runed": "^0.37.1",
        "svelte-sonner": "^1.1.0",
        "ua-parser-js": "^2.0.9",
        "vaul-svelte": "^0.3.2"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.0.2",
        "@iconify-json/logos": "^1.2.11",
        "@iconify-json/simple-icons": "^1.2.73",
        "@iconify-json/svg-spinners": "^1.2.4",
        "@iconify-json/tabler": "^1.2.31",
        "@repo/eslint-config": "workspace:*",
        "@repo/prettier-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.50.2",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.18",
        "@uiw/codemirror-themes-all": "^4.25.9",
        "clsx": "^2.1.1",
        "cross-env": "^10.1.0",
        "shiki": "^4.0.2",
        "svelte": "^5.49.1",
        "svelte-check": "^4.3.6",
        "svelte-turnstile": "^0.11.0",
