{
    "name": "server",
    "scripts": {
        "ba:generate": "bunx auth@latest generate --config ./src/lib/auth/index.ts --output ./src/lib/db/schema/ba-auth.ts --yes && bun run scripts/fix-ba-schema.ts",
        "dataset:convert-coc": "bun run scripts/migrations/convert-coc-to-json.ts",
        "dataset:migrate": "bun run scripts/migrations/migrate.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "dev": "NODE_ENV=development bun run --hot --no-clear-screen --preload ./src/lib/instrument.ts src/index.ts",
        "format": "prettier --write . --ignore-path ../../.prettierignore",
        "format:check": "prettier --check . --ignore-path ../../.prettierignore"
    },
    "prettier": "@repo/prettier-config",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1026.0",
        "@hono/bun-compress": "^0.1.0",
        "@hono/standard-validator": "^0.2.2",
        "@repo/clashofclans-api": "workspace:*",
        "@scalar/hono-api-reference": "^0.10.3",
        "@sentry/bun": "^10.43.0",
        "better-auth": "^1.4.18",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.11.7",
        "hono-openapi": "^1.3.0",
        "hono-rate-limiter": "^0.5.3",
        "ioredis": "^5.10.0",
        "pg": "^8.18.0",
        "rate-limit-redis": "^4.3.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@repo/eslint-config": "workspace:*",
        "@repo/prettier-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@types/bun": "latest",
        "@types/pg": "^8.16.0",
        "csv-parse": "^6.2.0",
        "discord-api-types": "^0.38.42",
        "drizzle-kit": "^0.31.8",
        "express": "^5.2.1"
    },
    "packageManager": "bun@1.3.3"
}
